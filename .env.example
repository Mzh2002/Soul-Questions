# Django
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# LLM Provider — set one of these
# Option A: OpenAI
OPENAI_API_KEY=sk-...
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Option B: Local / Ollama (set base URL)
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3
# OLLAMA_BASE_URL=http://localhost:11434

# Embedding provider
# Options: sentence-transformers, openai
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Vector store
# Options: chroma, faiss
VECTOR_STORE=chroma

# Paths (defaults work out of the box)
# DATA_RAW_DIR=data/raw
# DATA_PROCESSED_DIR=data/processed
# DATA_CHUNKS_DIR=data/chunks
# VECTORSTORE_DIR=data/vectorstore
