# Django
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Set for production behind a domain (comma-separated)
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# Database — leave empty for SQLite (dev), set for PostgreSQL (production)
# DATABASE_URL=postgres://soul:changeme@db:5432/soul_questions

# PostgreSQL password (used by docker-compose)
# POSTGRES_PASSWORD=changeme

# OpenAI
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# Embedding provider
# Options: sentence-transformers, openai
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Vector store
# Options: chroma, faiss
VECTOR_STORE=chroma

# Paths (defaults work out of the box)
# DATA_RAW_DIR=data/raw
# DATA_PROCESSED_DIR=data/processed
# DATA_CHUNKS_DIR=data/chunks
# VECTORSTORE_DIR=data/vectorstore
